# Groq API (free at console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# MongoDB Atlas (free M0 cluster at mongodb.com/atlas)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URL=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/autoui?retryWrites=true&w=majority
MONGODB_DB_NAME=autoui

# Upstash Redis (free at upstash.com) — optional, skip for local dev
REDIS_URL=rediss://:password@host.upstash.io:6379

# App settings
SECRET_KEY=your-secret-key-min-32-chars
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,https://autoui-optimizer.vercel.app
