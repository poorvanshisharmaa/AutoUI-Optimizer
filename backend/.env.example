# Groq API (free at console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# Supabase (free at supabase.com)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres

# Upstash Redis (free at upstash.com)
REDIS_URL=rediss://:[password]@[host].upstash.io:6379

# App settings
SECRET_KEY=your-secret-key-min-32-chars
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,https://autoui-optimizer.vercel.app
